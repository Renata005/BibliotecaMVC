@model LibraTech.Models.Usuario

@{
    ViewData["Title"] = "Detalhes do Usuário";
}

<div class="card shadow">

    <div class="card-header bg-primary text-white">

        <h3 class="mb-0">
            👤 Detalhes do Usuário
        </h3>

    </div>

    <div class="card-body">

        <dl class="row">

            <dt class="col-sm-3">
                Nome
            </dt>

            <dd class="col-sm-9">
                @Model.Nome
            </dd>

            <dt class="col-sm-3">
                CPF
            </dt>

            <dd class="col-sm-9">
                @Model.CPF
            </dd>

            <dt class="col-sm-3">
                Telefone
            </dt>

            <dd class="col-sm-9">
                @Model.Telefone
            </dd>

            <dt class="col-sm-3">
                E-mail
            </dt>

            <dd class="col-sm-9">
                @Model.Email
            </dd>

        </dl>

        <hr />

        <a asp-action="Edit"
           asp-route-id="@Model.Id"
           class="btn btn-warning">

            ✏️ Editar

        </a>

        <a asp-action="Index"
           class="btn btn-secondary">

            Voltar

        </a>

    </div>

</div>