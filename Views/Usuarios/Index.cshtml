@model IEnumerable<LibraTech.Models.Usuario>

@{
    ViewData["Title"] = "Usuários";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2>👤 Usuários</h2>

        <a asp-action="Create" class="btn btn-primary">
            + Novo Usuário
        </a>

    </div>

    <div class="card shadow">

        <div class="card-body">

            <input class="form-control mb-4"
                   id="pesquisaUsuario"
                   type="text"
                   placeholder="🔍 Pesquisar usuário..." />

            <table class="table table-hover align-middle" id="tabelaUsuarios">

                <thead class="table-primary">

                    <tr>

                        <th width="70">Perfil</th>

                        <th>Nome</th>

                        <th>CPF</th>

                        <th>Telefone</th>

                        <th>E-mail</th>

                        <th width="220">Ações</th>

                    </tr>

                </thead>

                <tbody>

@foreach (var item in Model)
{
                    <tr>

                        <td>

                            <img src="https://ui-avatars.com/api/?name=@item.Nome&background=0D6EFD&color=fff&rounded=true&size=48"
                                 class="rounded-circle" />

                        </td>

                        <td>

                            <strong>@item.Nome</strong>

                        </td>

                        <td>

                            @item.CPF

                        </td>

                        <td>

                            @item.Telefone

                        </td>

                        <td>

                            @item.Email

                        </td>

                        <td>

                            <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="btn btn-info btn-sm text-white">
                                Detalhes
                            </a>

                            <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               class="btn btn-warning btn-sm">
                                Editar
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.Id"
                               class="btn btn-danger btn-sm">
                                Excluir
                            </a>

                        </td>

                    </tr>
}

                </tbody>

            </table>

        </div>

    </div>

</div>

@section Scripts{

<script>

document.getElementById("pesquisaUsuario").addEventListener("keyup", function(){

    let valor = this.value.toLowerCase();

    let linhas = document.querySelectorAll("#tabelaUsuarios tbody tr");

    linhas.forEach(function(linha){

        linha.style.display =
            linha.innerText.toLowerCase().includes(valor)
            ? ""
            : "none";

    });

});

</script>

}