@model LibraTech.Models.Usuario

@{
    ViewData["Title"] = "Excluir Usuário";
}

<div class="card shadow border-danger">

    <div class="card-header bg-danger text-white">

        <h3 class="mb-0">
            🗑️ Excluir Usuário
        </h3>

    </div>

    <div class="card-body">

        <div class="alert alert-warning">

            Tem certeza que deseja excluir este usuário?

        </div>

        <dl class="row">

            <dt class="col-sm-3">
                Nome
            </dt>

            <dd class="col-sm-9">
                @Model.Nome
            </dd>

            <dt class="col-sm-3">
                CPF
            </dt>

            <dd class="col-sm-9">
                @Model.CPF
            </dd>

            <dt class="col-sm-3">
                Telefone
            </dt>

            <dd class="col-sm-9">
                @Model.Telefone
            </dd>

            <dt class="col-sm-3">
                E-mail
            </dt>

            <dd class="col-sm-9">
                @Model.Email
            </dd>

        </dl>

        <form asp-action="Delete">

            <input type="hidden" asp-for="Id" />

            <button type="submit"
                    class="btn btn-danger">

                🗑️ Excluir

            </button>

            <a asp-action="Index"
               class="btn btn-secondary">

                Cancelar

            </a>

        </form>

    </div>

</div>