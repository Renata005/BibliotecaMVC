@model LibraTech.Models.Livro

@{
    ViewData["Title"] = "Editar Livro";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">📚 Editar Livro</h3>
        </div>

        <div class="card-body">

            <form asp-action="Edit">

                <input type="hidden" asp-for="Id" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label asp-for="Titulo" class="form-label"></label>
                        <input asp-for="Titulo" class="form-control" />
                        <span asp-validation-for="Titulo" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Autor" class="form-label"></label>
                        <input asp-for="Autor" class="form-control" />
                        <span asp-validation-for="Autor" class="text-danger"></span>
                    </div>

                </div>

                <div class="row">

                    <div class="col-md-4 mb-3">
                        <label asp-for="AnoPublicacao" class="form-label"></label>
                        <input asp-for="AnoPublicacao" class="form-control" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="ISBN" class="form-label"></label>
                        <input asp-for="ISBN" class="form-control" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="Quantidade" class="form-label"></label>
                        <input asp-for="Quantidade" class="form-control" />
                    </div>

                </div>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label asp-for="Editora" class="form-label"></label>
                        <input asp-for="Editora" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="CategoriaId" class="form-label"></label>
                        <select asp-for="CategoriaId"
                                class="form-select"
                                asp-items="ViewBag.CategoriaId"></select>
                    </div>

                </div>

                <div class="mb-3">
                    <label asp-for="CapaUrl" class="form-label"></label>
                    <input asp-for="CapaUrl" class="form-control" />
                </div>

                <div class="mb-3">
                    <label asp-for="Sinopse" class="form-label"></label>
                    <textarea asp-for="Sinopse"
                              rows="5"
                              class="form-control"></textarea>
                </div>

                <hr />

                <button type="submit" class="btn btn-success">
                    💾 Salvar Alterações
                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">
                    Cancelar
                </a>

            </form>

        </div>

    </div>

</div>

@section Scripts{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}