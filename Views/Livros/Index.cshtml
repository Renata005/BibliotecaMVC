@model IEnumerable<LibraTech.Models.Livro>

@{
    ViewData["Title"] = "Livros";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2>📚 Biblioteca</h2>

        <a asp-action="Create" class="btn btn-primary">
            + Novo Livro
        </a>

    </div>

    <div class="card shadow">

        <div class="card-body">

            <input class="form-control mb-4"
                   id="pesquisaLivro"
                   type="text"
                   placeholder="🔍 Pesquisar livro..." />

            <table class="table table-hover align-middle" id="tabelaLivros">

                <thead class="table-primary">

                    <tr>

                        <th width="90">Capa</th>

                        <th>Título</th>

                        <th>Autor</th>

                        <th>Categoria</th>

                        <th>Quantidade</th>

                        <th width="220">Ações</th>

                    </tr>

                </thead>

                <tbody>

@foreach(var item in Model)
{
                    <tr>

                        <td>

@if(!string.IsNullOrWhiteSpace(item.CapaUrl))
{
                            <img src="@item.CapaUrl"
                                 style="width:60px;height:90px;object-fit:cover;border-radius:8px;" />
}
else
{
                            <img src="https://placehold.co/60x90?text=Livro"
                                 style="border-radius:8px;" />
}

                        </td>

                        <td>

                            <strong>@item.Titulo</strong>

                            <br />

                            <small class="text-muted">
                                @item.Editora
                            </small>

                        </td>

                        <td>

                            @item.Autor

                        </td>

                        <td>

                            <span class="badge bg-primary">

                                @item.Categoria?.Nome

                            </span>

                        </td>

                        <td>

@if(item.Quantidade > 5)
{
                            <span class="badge bg-success">
                                @item.Quantidade
                            </span>
}
else if(item.Quantidade > 0)
{
                            <span class="badge bg-warning text-dark">
                                @item.Quantidade
                            </span>
}
else
{
                            <span class="badge bg-danger">
                                Esgotado
                            </span>
}

                        </td>

                        <td>

                            <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="btn btn-info btn-sm text-white">
                                Detalhes
                            </a>

                            <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               class="btn btn-warning btn-sm">
                                Editar
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.Id"
                               class="btn btn-danger btn-sm">
                                Excluir
                            </a>

                        </td>

                    </tr>
}

                </tbody>

            </table>

        </div>

    </div>

</div>

@section Scripts{

<script>

document.getElementById("pesquisaLivro").addEventListener("keyup", function () {

    let valor = this.value.toLowerCase();

    let linhas = document.querySelectorAll("#tabelaLivros tbody tr");

    linhas.forEach(function(linha){

        linha.style.display =
            linha.innerText.toLowerCase().includes(valor)
            ? ""
            : "none";

    });

});

</script>

}