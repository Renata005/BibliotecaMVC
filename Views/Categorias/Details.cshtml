@model LibraTech.Models.Categoria

@{
    ViewData["Title"] = "Detalhes da Categoria";
}

<div class="row justify-content-center">

    <div class="col-lg-8">

        <div class="card shadow">

            <div class="card-header bg-info text-white">

                <h3 class="mb-0">
                    📂 Detalhes da Categoria
                </h3>

            </div>

            <div class="card-body">

                <dl class="row">

                    <dt class="col-sm-3">
                        Nome
                    </dt>

                    <dd class="col-sm-9">
                        @Model.Nome
                    </dd>

                    <dt class="col-sm-3">
                        Descrição
                    </dt>

                    <dd class="col-sm-9">
                        @Model.Descricao
                    </dd>

                </dl>

                <hr />

                <a asp-action="Edit"
                   asp-route-id="@Model.Id"
                   class="btn btn-warning">

                    Editar

                </a>

                <a asp-action="Index"
                   class="btn btn-secondary">

                    Voltar

                </a>

            </div>

        </div>

    </div>

</div>