@model IEnumerable<LibraTech.Models.Emprestimo>

@{
    ViewData["Title"] = "Empréstimos";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2>📖 Empréstimos</h2>

        <a asp-action="Create" class="btn btn-primary">
            + Novo Empréstimo
        </a>

    </div>

    <div class="card shadow">

        <div class="card-body">

            <input class="form-control mb-4"
                   id="pesquisaEmprestimo"
                   type="text"
                   placeholder="🔍 Pesquisar livro ou usuário..." />

            <table class="table table-hover align-middle" id="tabelaEmprestimos">

                <thead class="table-primary">

                    <tr>

                        <th>Livro</th>

                        <th>Usuário</th>

                        <th>Empréstimo</th>

                        <th>Devolução</th>

                        <th>Status</th>

                        <th width="220">Ações</th>

                    </tr>

                </thead>

                <tbody>

@foreach (var item in Model)
{
                    <tr>

                        <td>

                            <strong>@item.Livro?.Titulo</strong>

                        </td>

                        <td>

                            @item.Usuario?.Nome

                        </td>

                        <td>

                            @item.DataEmprestimo.ToString("dd/MM/yyyy")

                        </td>

                        <td>

                            @item.DataDevolucao.ToString("dd/MM/yyyy")

                        </td>

                        <td>

@if(item.Devolvido)
{
                            <span class="badge bg-success">
                                ✔ Devolvido
                            </span>
}
else if(item.DataDevolucao < DateTime.Today)
{
                            <span class="badge bg-danger">
                                ⚠ Atrasado
                            </span>
}
else
{
                            <span class="badge bg-warning text-dark">
                                📖 Em andamento
                            </span>
}

                        </td>

                        <td>

                            <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="btn btn-info btn-sm text-white">
                                Detalhes
                            </a>

                            <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               class="btn btn-warning btn-sm">
                                Editar
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.Id"
                               class="btn btn-danger btn-sm">
                                Excluir
                            </a>

                        </td>

                    </tr>
}

                </tbody>

            </table>

        </div>

    </div>

</div>

@section Scripts{

<script>

document.getElementById("pesquisaEmprestimo").addEventListener("keyup", function(){

    let valor = this.value.toLowerCase();

    let linhas = document.querySelectorAll("#tabelaEmprestimos tbody tr");

    linhas.forEach(function(linha){

        linha.style.display =
            linha.innerText.toLowerCase().includes(valor)
            ? ""
            : "none";

    });

});

</script>

}