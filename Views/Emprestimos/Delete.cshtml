@model LibraTech.Models.Emprestimo

@{
    ViewData["Title"] = "Excluir Empréstimo";
}

<h1>🗑️ Excluir Empréstimo</h1>

<h3 class="text-danger">
    Tem certeza que deseja excluir este empréstimo?
</h3>

<hr />

<dl class="row">

    <dt class="col-sm-2">
        Livro
    </dt>

    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.Livro.Titulo)
    </dd>

    <dt class="col-sm-2">
        Usuário
    </dt>

    <dd class="col-sm-10">
        @Html.DisplayFor(model => model.Usuario.Nome)
    </dd>

    <dt class="col-sm-2">
        Data do Empréstimo
    </dt>

    <dd class="col-sm-10">
        @Model.DataEmprestimo.ToString("dd/MM/yyyy")
    </dd>

    <dt class="col-sm-2">
        Data da Devolução
    </dt>

    <dd class="col-sm-10">
        @Model.DataDevolucao.ToString("dd/MM/yyyy")
    </dd>

    <dt class="col-sm-2">
        Situação
    </dt>

    <dd class="col-sm-10">

        @if (Model.Devolvido)
        {
            <span class="badge bg-success">
                Devolvido
            </span>
        }
        else
        {
            <span class="badge bg-warning text-dark">
                Emprestado
            </span>
        }

    </dd>

</dl>

<form asp-action="Delete">

    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">
        🗑️ Excluir
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Voltar
    </a>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}