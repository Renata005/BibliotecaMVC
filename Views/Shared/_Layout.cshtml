<!DOCTYPE html>
<html lang="pt-br">
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - LibraTech</title>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/LibraTech.styles.css"
          asp-append-version="true" />

    <link rel="preconnect" href="https://fonts.googleapis.com">

    <link rel="preconnect"
          href="https://fonts.gstatic.com"
          crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
          rel="stylesheet">

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

</head>

<body>

    <header>

        <nav class="navbar navbar-expand-lg navbar-dark shadow-sm">

            <div class="container">

                <a class="navbar-brand d-flex align-items-center py-2"
                   asp-controller="Home"
                   asp-action="Index">

                    <img src="~/images/logo.png"
                    alt="LibraTech"
                    style="height:95px; width:auto;" />

                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#menu">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <div class="collapse navbar-collapse"
                     id="menu">

                    <ul class="navbar-nav ms-auto">

                        <li class="nav-item mx-1">
                            <a class="nav-link px-3"
                               asp-controller="Home"
                               asp-action="Index">
                                🏠 Início
                            </a>
                        </li>

                        <li class="nav-item mx-1">
                            <a class="nav-link px-3"
                               asp-controller="Livros"
                               asp-action="Index">
                                📚 Livros
                            </a>
                        </li>

                        <li class="nav-item mx-1">
                            <a class="nav-link px-3"
                               asp-controller="Categorias"
                               asp-action="Index">
                                📂 Categorias
                            </a>
                        </li>

                        <li class="nav-item mx-1">
                            <a class="nav-link px-3"
                               asp-controller="Usuarios"
                               asp-action="Index">
                                👤 Usuários
                            </a>
                        </li>

                        <li class="nav-item mx-1">
                            <a class="nav-link px-3"
                               asp-controller="Emprestimos"
                               asp-action="Index">
                                📖 Empréstimos
                            </a>
                        </li>

                        <li class="nav-item mx-1">
                            <a class="nav-link px-3"
                                asp-controller="Home"
                                asp-action="Contato">
                                 ✉️ Contato
                            </a>
                        </li>

                    </ul>

                </div>

            </div>

        </nav>

    </header>

    <main class="container py-4">

        @RenderBody()

    </main>

    <footer class="mt-5">

        <div class="container text-center py-4">

            <hr />

            <p class="mb-0">

                © @DateTime.Now.Year - <strong>LibraTech</strong>

            </p>

            <small>

                Sistema Inteligente de Gerenciamento de Bibliotecas

            </small>

        </div>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
